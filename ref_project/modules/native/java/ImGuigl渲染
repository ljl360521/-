public class ImGui {
    private static final String TAG = "ImGui";
    private static final String IMGUI_VIEW_TAG = "imgui_overlay_view";
    private static GLES3JNIView display;
    private WeakReference<Activity> currentActivityRef;

    private static final int MAX_POINTERS = 10;
    private boolean[] pointerInImGui = new boolean[MAX_POINTERS];
    private boolean[] pointerInButton = new boolean[MAX_POINTERS];

    private Map<Integer, Integer> gamePointerIdMap = new HashMap<>();
    private List<Integer> activeGamePointers = new ArrayList<>();
    private long gameDownTime = 0;

    private int imguiPointerCount = 0;

    // ========================================================================
    // 命名静态内部类 - 避免匿名类/lambda 导致 D8 崩溃
    // ========================================================================

    private static class VolumeKeyCallback implements InvocationHandler {
        private final android.view.Window.Callback originalCallback;
        private final Activity activity;

        VolumeKeyCallback(android.view.Window.Callback originalCallback, Activity activity) {
            this.originalCallback = originalCallback;
            this.activity = activity;
        }

        @Override
        public Object invoke(Object proxy, Method method, Object[] args) throws Throwable {
            if ("dispatchKeyEvent".equals(method.getName()) && args != null && args.length == 1 && args[0] instanceof KeyEvent) {
                KeyEvent event = (KeyEvent) args[0];
                int keyCode = event.getKeyCode();
                if (GLES3JNIView.interceptVolumeKeys && isVolumeKey(keyCode) && activity.hasWindowFocus()) {
                    if (event.getAction() == KeyEvent.ACTION_DOWN) {
                        GLES3JNIView.nativeOnKeyEvent(0, keyCode, event.getScanCode(),
                            event.getMetaState(), event.getDeviceId(), event.getSource());
                    } else if (event.getAction() == KeyEvent.ACTION_UP) {
                        GLES3JNIView.nativeOnKeyEvent(1, keyCode, event.getScanCode(),
                            event.getMetaState(), event.getDeviceId(), event.getSource());
                    }
                    return true;
                }
            }
            return method.invoke(originalCallback, args);
        }

        private boolean isVolumeKey(int keyCode) {
            return keyCode == KeyEvent.KEYCODE_VOLUME_UP
                || keyCode == KeyEvent.KEYCODE_VOLUME_DOWN
                || keyCode == KeyEvent.KEYCODE_VOLUME_MUTE;
        }
    }

    private static class SurfaceSecurityAttachListener implements View.OnAttachStateChangeListener {
        private final GLES3JNIView view;

        SurfaceSecurityAttachListener(GLES3JNIView view) {
            this.view = view;
        }

        @Override
        public void onViewAttachedToWindow(View v) {
            view.post(new SurfaceSecurityRunnable(view));
        }

        @Override
        public void onViewDetachedFromWindow(View v) {
        }
    }

    private static class SurfaceSecurityRunnable implements Runnable {
        private final GLES3JNIView view;

        SurfaceSecurityRunnable(GLES3JNIView view) {
            this.view = view;
        }

        @Override
        public void run() {
            view.applySurfaceSecurity();
        }
    }

    private static class SetupRunnable implements Runnable {
        private final ImGui imgui;
        private final Activity activity;

        SetupRunnable(ImGui imgui, Activity activity) {
            this.imgui = imgui;
            this.activity = activity;
        }

        @Override
        public void run() {
            imgui.setupImGuiViewInternal(activity);
        }
    }

    private static class SetupOnMainThreadRunnable implements Runnable {
        private final Activity activity;

        SetupOnMainThreadRunnable(Activity activity) {
            this.activity = activity;
        }

        @Override
        public void run() {
            Log.i(TAG, "Now on main thread, executing setupImGuiViewImpl");
            ImGui imgui = new ImGui();
            imgui.setupImGuiView(activity);
        }
    }

    private static class ImGuiTouchListener implements View.OnTouchListener {
        private final ImGui imgui;
        private final ViewGroup rootView;

        ImGuiTouchListener(ImGui imgui, ViewGroup rootView) {
            this.imgui = imgui;
            this.rootView = rootView;
        }

        @Override
        public boolean onTouch(View v, MotionEvent event) {
            int source = event.getSource();

            if ((source & InputDevice.SOURCE_MOUSE) == InputDevice.SOURCE_MOUSE) {
                return imgui.handleMouseTouchEvent(v, event, rootView);
            }

            return imgui.handleTouchEvent(v, event, rootView);
        }
    }

    private static class ImGuiKeyListener implements View.OnKeyListener {
        @Override
        public boolean onKey(View v, int keyCode, KeyEvent event) {
            return false;
        }
    }

    // ========================================================================
    // 初始化
    // ========================================================================

    private void initPointerTracking() {
        for (int i = 0; i < MAX_POINTERS; i++) {
            pointerInImGui[i] = false;
            pointerInButton[i] = false;
        }
        imguiPointerCount = 0;
        gamePointerIdMap.clear();
        activeGamePointers.clear();
        gameDownTime = 0;
    }

    public static void setupImGuiViewOnMainThread(Activity activity) {
        Log.i(TAG, "setupImGuiViewOnMainThread called");

        if (Looper.getMainLooper() == Looper.myLooper()) {
            Log.i(TAG, "Already on main thread, executing directly");
            ImGui imgui = new ImGui();
            imgui.setupImGuiView(activity);
        } else {
            Log.i(TAG, "Not on main thread, using Handler to switch");
            Handler mainHandler = new Handler(Looper.getMainLooper());
            mainHandler.post(new SetupOnMainThreadRunnable(activity));
        }
    }

    public void setupImGuiView(final Activity activity) {
        if (Looper.myLooper() != Looper.getMainLooper()) {
            new Handler(Looper.getMainLooper()).post(new SetupRunnable(this, activity));
        } else {
            setupImGuiViewInternal(activity);
        }
    }

    private void setupImGuiViewInternal(Activity activity) {
        try {
            initPointerTracking();

            FrameLayout rootView = activity.findViewById(android.R.id.content);
            if (rootView == null) {
                Log.e(TAG, "Root view is null");
                return;
            }

            if (rootView.findViewWithTag(IMGUI_VIEW_TAG) != null) {
                Log.i(TAG, "IMGUI view already exists");
                return;
            }

            currentActivityRef = new WeakReference<>(activity);

            Log.i(TAG, "Initializing IMEHelper");
            IMEHelper.init(activity);
            Log.i(TAG, "IMEHelper initialized");
            ImGuiToolsHelper.init(activity);

            display = new GLES3JNIView(activity);
            display.setFocusable(true);
            display.setFocusableInTouchMode(true);
            display.requestFocus();

            display.setTag(IMGUI_VIEW_TAG);
            display.setZOrderOnTop(true);
            display.getHolder().setFormat(PixelFormat.TRANSLUCENT);

            // 使用命名类设置触摸监听
            display.setOnTouchListener(new ImGuiTouchListener(this, rootView));

            // 使用命名类设置按键监听
            display.setOnKeyListener(new ImGuiKeyListener());

            // 使用命名类监听 attach 状态
            display.addOnAttachStateChangeListener(new SurfaceSecurityAttachListener(display));

            FrameLayout.LayoutParams layoutParams =
                    new FrameLayout.LayoutParams(
                            FrameLayout.LayoutParams.MATCH_PARENT,
                            FrameLayout.LayoutParams.MATCH_PARENT);
            display.setLayoutParams(layoutParams);
            rootView.addView(display);
            hookActivityKeyEvent(activity);

            Log.i(TAG, "ImGui view setup completed successfully");

        } catch (Exception e) {
            Log.e(TAG, "Error in setupImGuiViewInternal", e);
            e.printStackTrace();
        }
    }

    private void hookActivityKeyEvent(Activity activity) {
        final android.view.Window window = activity.getWindow();
        final android.view.Window.Callback originalCallback = window.getCallback();
        if (originalCallback == null) return;

        android.view.Window.Callback proxy = (android.view.Window.Callback) Proxy.newProxyInstance(
            originalCallback.getClass().getClassLoader(),
            new Class[]{android.view.Window.Callback.class},
            new VolumeKeyCallback(originalCallback, activity)
        );

        window.setCallback(proxy);
    }

    // ========================================================================
    // 鼠标事件处理
    // ========================================================================

    private boolean handleMouseTouchEvent(View v, MotionEvent event, ViewGroup rootView) {
        int action = event.getActionMasked();
        float x = event.getX();
        float y = event.getY();
        int deviceId = event.getDeviceId();
        int source = event.getSource();

        int button = 0;
        int buttonState = event.getButtonState();
        if ((buttonState & MotionEvent.BUTTON_SECONDARY) != 0) {
            button = 1;
        } else if ((buttonState & MotionEvent.BUTTON_TERTIARY) != 0) {
            button = 2;
        } else if ((buttonState & MotionEvent.BUTTON_BACK) != 0) {
            button = 3;
        } else if ((buttonState & MotionEvent.BUTTON_FORWARD) != 0) {
            button = 4;
        }

        switch (action) {
            case MotionEvent.ACTION_DOWN:
                GLES3JNIView.nativeOnMouseEvent(1, x, y, button, 0, 0, deviceId, source);
                return handleTouchEvent(v, event, rootView);

            case MotionEvent.ACTION_UP:
                GLES3JNIView.nativeOnMouseEvent(2, x, y, button, 0, 0, deviceId, source);
                return handleTouchEvent(v, event, rootView);

            case MotionEvent.ACTION_MOVE:
                GLES3JNIView.nativeOnMouseEvent(0, x, y, 0, 0, 0, deviceId, source);
                return handleTouchEvent(v, event, rootView);

            default:
                return handleTouchEvent(v, event, rootView);
        }
    }

    // ========================================================================
    // 触摸事件处理
    // ========================================================================

    private boolean handleTouchEvent(View v, MotionEvent event, ViewGroup rootView) {
        int action = event.getActionMasked();
        int pointerIndex = event.getActionIndex();
        int pointerCount = event.getPointerCount();

        int[] pointerIds = new int[pointerCount];
        float[] pointerXs = new float[pointerCount];
        float[] pointerYs = new float[pointerCount];
        float[] pointerPressures = new float[pointerCount];

        for (int i = 0; i < pointerCount; i++) {
            pointerIds[i] = event.getPointerId(i);
            pointerXs[i] = event.getX(i);
            pointerYs[i] = event.getY(i);
            pointerPressures[i] = event.getPressure(i);
        }

        GLES3JNIView.nativeOnTouchEvent(
                action,
                pointerIndex,
                pointerIds,
                pointerXs,
                pointerYs,
                pointerPressures,
                pointerCount);

        switch (action) {
            case MotionEvent.ACTION_DOWN:
                {
                    int pointerId = event.getPointerId(pointerIndex);
                    float x = event.getX(pointerIndex);
                    float y = event.getY(pointerIndex);

                    boolean inImGui = isImGuiComponentTouched(x, y);
                    boolean inButton = isCircularButtonTouched(x, y);

                    pointerInImGui[pointerId] = inImGui;
                    pointerInButton[pointerId] = inButton;

                    if (inImGui || inButton) {
                        imguiPointerCount++;
                        if (inImGui) {
                            GLES3JNIView.MotionEventClick(true, x, y);
                        }
                        return true;
                    }

                    return false;
                }

            case MotionEvent.ACTION_POINTER_DOWN:
                {
                    int pointerId = event.getPointerId(pointerIndex);
                    float x = event.getX(pointerIndex);
                    float y = event.getY(pointerIndex);

                    boolean inImGui = isImGuiComponentTouched(x, y);
                    boolean inButton = isCircularButtonTouched(x, y);

                    pointerInImGui[pointerId] = inImGui;
                    pointerInButton[pointerId] = inButton;

                    if (inImGui || inButton) {
                        imguiPointerCount++;
                        if (inImGui) {
                            GLES3JNIView.MotionEventClick(true, x, y);
                        }
                    } else {
                        addGamePointer(pointerId);
                        dispatchGameEvent(event, MotionEvent.ACTION_DOWN, pointerId, rootView);
                    }

                    return imguiPointerCount > 0 || activeGamePointers.size() > 0;
                }

            case MotionEvent.ACTION_MOVE:
                {
                    for (int i = 0; i < pointerCount; i++) {
                        int pointerId = event.getPointerId(i);
                        float x = event.getX(i);
                        float y = event.getY(i);

                        if (pointerInImGui[pointerId]) {
                            GLES3JNIView.MotionEventClick(true, x, y);
                        }
                    }

                    if (!activeGamePointers.isEmpty()) {
                        dispatchGameMoveEvent(event, rootView);
                    }

                    return imguiPointerCount > 0 || !activeGamePointers.isEmpty();
                }

            case MotionEvent.ACTION_UP:
                {
                    int pointerId = event.getPointerId(pointerIndex);
                    float x = event.getX(pointerIndex);
                    float y = event.getY(pointerIndex);

                    boolean wasInImGui = pointerInImGui[pointerId];
                    boolean wasInButton = pointerInButton[pointerId];

                    if (wasInImGui) {
                        GLES3JNIView.MotionEventClick(false, x, y);
                        imguiPointerCount--;
                    } else if (wasInButton) {
                        imguiPointerCount--;
                    } else if (activeGamePointers.contains(pointerId)) {
                        dispatchGameEvent(event, MotionEvent.ACTION_UP, pointerId, rootView);
                        removeGamePointer(pointerId);
                    }

                    pointerInImGui[pointerId] = false;
                    pointerInButton[pointerId] = false;

                    if (imguiPointerCount == 0 && activeGamePointers.isEmpty()) {
                        gameDownTime = 0;
                    }

                    return wasInImGui || wasInButton || !activeGamePointers.isEmpty();
                }

            case MotionEvent.ACTION_POINTER_UP:
                {
                    int pointerId = event.getPointerId(pointerIndex);
                    float x = event.getX(pointerIndex);
                    float y = event.getY(pointerIndex);

                    boolean wasInImGui = pointerInImGui[pointerId];
                    boolean wasInButton = pointerInButton[pointerId];

                    if (wasInImGui) {
                        GLES3JNIView.MotionEventClick(false, x, y);
                        imguiPointerCount--;
                    } else if (wasInButton) {
                        imguiPointerCount--;
                    } else if (activeGamePointers.contains(pointerId)) {
                        int gameAction = MotionEvent.ACTION_POINTER_UP;
                        dispatchGameEvent(event, gameAction, pointerId, rootView);
                        removeGamePointer(pointerId);
                    }

                    pointerInImGui[pointerId] = false;
                    pointerInButton[pointerId] = false;

                    return imguiPointerCount > 0 || !activeGamePointers.isEmpty();
                }

            case MotionEvent.ACTION_CANCEL:
                {
                    for (int i = 0; i < pointerCount; i++) {
                        int pointerId = event.getPointerId(i);
                        if (pointerInImGui[pointerId]) {
                            float x = event.getX(i);
                            float y = event.getY(i);
                            GLES3JNIView.MotionEventClick(false, x, y);
                        }
                        pointerInImGui[pointerId] = false;
                        pointerInButton[pointerId] = false;
                    }

                    if (!activeGamePointers.isEmpty()) {
                        dispatchGameCancelEvent(event, rootView);
                    }

                    imguiPointerCount = 0;
                    gamePointerIdMap.clear();
                    activeGamePointers.clear();
                    gameDownTime = 0;

                    return false;
                }
        }

        return false;
    }

    // ========================================================================
    // 游戏触摸分发
    // ========================================================================

    private void addGamePointer(int originalPointerId) {
        if (!activeGamePointers.contains(originalPointerId)) {
            int gamePointerId = activeGamePointers.size();
            gamePointerIdMap.put(originalPointerId, gamePointerId);
            activeGamePointers.add(originalPointerId);

            if (activeGamePointers.size() == 1) {
                gameDownTime = SystemClock.uptimeMillis();
            }
        }
    }

    private void removeGamePointer(int originalPointerId) {
        activeGamePointers.remove(Integer.valueOf(originalPointerId));
        gamePointerIdMap.remove(originalPointerId);

        gamePointerIdMap.clear();
        for (int i = 0; i < activeGamePointers.size(); i++) {
            gamePointerIdMap.put(activeGamePointers.get(i), i);
        }
    }

    private void dispatchGameEvent(
            MotionEvent originalEvent, int action, int targetPointerId, ViewGroup rootView) {
        try {
            int gamePointerCount = activeGamePointers.size();
            if (gamePointerCount == 0) return;

            int targetGameIndex = activeGamePointers.indexOf(targetPointerId);
            if (targetGameIndex == -1 && action == MotionEvent.ACTION_DOWN) {
                targetGameIndex = gamePointerCount - 1;
            }

            MotionEvent.PointerProperties[] props =
                    new MotionEvent.PointerProperties[gamePointerCount];
            MotionEvent.PointerCoords[] coords = new MotionEvent.PointerCoords[gamePointerCount];

            for (int i = 0; i < gamePointerCount; i++) {
                int origPointerId = activeGamePointers.get(i);
                int origIndex = findPointerIndex(originalEvent, origPointerId);

                props[i] = new MotionEvent.PointerProperties();
                coords[i] = new MotionEvent.PointerCoords();

                if (origIndex >= 0) {
                    originalEvent.getPointerProperties(origIndex, props[i]);
                    originalEvent.getPointerCoords(origIndex, coords[i]);
                } else {
                    props[i].id = origPointerId;
                    props[i].toolType = MotionEvent.TOOL_TYPE_FINGER;
                    coords[i].x = 0;
                    coords[i].y = 0;
                    coords[i].pressure = 1.0f;
                    coords[i].size = 1.0f;
                }
            }

            int finalAction;
            if (action == MotionEvent.ACTION_DOWN) {
                if (gamePointerCount == 1) {
                    finalAction = MotionEvent.ACTION_DOWN;
                } else {
                    finalAction =
                            MotionEvent.ACTION_POINTER_DOWN
                                    | (targetGameIndex << MotionEvent.ACTION_POINTER_INDEX_SHIFT);
                }
            } else if (action == MotionEvent.ACTION_UP) {
                if (gamePointerCount == 1) {
                    finalAction = MotionEvent.ACTION_UP;
                } else {
                    int upIndex = targetGameIndex;
                    finalAction =
                            MotionEvent.ACTION_POINTER_UP
                                    | (upIndex << MotionEvent.ACTION_POINTER_INDEX_SHIFT);
                }
            } else if (action == MotionEvent.ACTION_POINTER_UP) {
                finalAction =
                        MotionEvent.ACTION_POINTER_UP
                                | (targetGameIndex << MotionEvent.ACTION_POINTER_INDEX_SHIFT);
            } else {
                finalAction = action;
            }

            MotionEvent newEvent =
                    MotionEvent.obtain(
                            gameDownTime,
                            originalEvent.getEventTime(),
                            finalAction,
                            gamePointerCount,
                            props,
                            coords,
                            originalEvent.getMetaState(),
                            originalEvent.getButtonState(),
                            originalEvent.getXPrecision(),
                            originalEvent.getYPrecision(),
                            originalEvent.getDeviceId(),
                            originalEvent.getEdgeFlags(),
                            originalEvent.getSource(),
                            originalEvent.getFlags());

            dispatchToChildren(rootView, newEvent);
            newEvent.recycle();

        } catch (Exception e) {
            Log.e(TAG, "Exception in dispatchGameEvent", e);
        }
    }

    private void dispatchGameMoveEvent(MotionEvent originalEvent, ViewGroup rootView) {
        try {
            int gamePointerCount = activeGamePointers.size();
            if (gamePointerCount == 0) return;

            MotionEvent.PointerProperties[] props =
                    new MotionEvent.PointerProperties[gamePointerCount];
            MotionEvent.PointerCoords[] coords = new MotionEvent.PointerCoords[gamePointerCount];

            for (int i = 0; i < gamePointerCount; i++) {
                int origPointerId = activeGamePointers.get(i);
                int origIndex = findPointerIndex(originalEvent, origPointerId);

                props[i] = new MotionEvent.PointerProperties();
                coords[i] = new MotionEvent.PointerCoords();

                if (origIndex >= 0) {
                    originalEvent.getPointerProperties(origIndex, props[i]);
                    originalEvent.getPointerCoords(origIndex, coords[i]);
                    props[i].id = origPointerId;
                } else {
                    props[i].id = origPointerId;
                    props[i].toolType = MotionEvent.TOOL_TYPE_FINGER;
                    coords[i].x = 0;
                    coords[i].y = 0;
                    coords[i].pressure = 1.0f;
                    coords[i].size = 1.0f;
                }
            }

            MotionEvent newEvent =
                    MotionEvent.obtain(
                            gameDownTime,
                            originalEvent.getEventTime(),
                            MotionEvent.ACTION_MOVE,
                            gamePointerCount,
                            props,
                            coords,
                            originalEvent.getMetaState(),
                            originalEvent.getButtonState(),
                            originalEvent.getXPrecision(),
                            originalEvent.getYPrecision(),
                            originalEvent.getDeviceId(),
                            originalEvent.getEdgeFlags(),
                            originalEvent.getSource(),
                            originalEvent.getFlags());

            dispatchToChildren(rootView, newEvent);
            newEvent.recycle();

        } catch (Exception e) {
            Log.e(TAG, "Exception in dispatchGameMoveEvent", e);
        }
    }

    private void dispatchGameCancelEvent(MotionEvent originalEvent, ViewGroup rootView) {
        try {
            int gamePointerCount = activeGamePointers.size();
            if (gamePointerCount == 0) return;

            MotionEvent.PointerProperties[] props =
                    new MotionEvent.PointerProperties[gamePointerCount];
            MotionEvent.PointerCoords[] coords = new MotionEvent.PointerCoords[gamePointerCount];

            for (int i = 0; i < gamePointerCount; i++) {
                int origPointerId = activeGamePointers.get(i);
                int origIndex = findPointerIndex(originalEvent, origPointerId);

                props[i] = new MotionEvent.PointerProperties();
                coords[i] = new MotionEvent.PointerCoords();

                if (origIndex >= 0) {
                    originalEvent.getPointerProperties(origIndex, props[i]);
                    originalEvent.getPointerCoords(origIndex, coords[i]);
                }

                props[i].id = i;
            }

            MotionEvent newEvent =
                    MotionEvent.obtain(
                            gameDownTime,
                            originalEvent.getEventTime(),
                            MotionEvent.ACTION_CANCEL,
                            gamePointerCount,
                            props,
                            coords,
                            originalEvent.getMetaState(),
                            originalEvent.getButtonState(),
                            originalEvent.getXPrecision(),
                            originalEvent.getYPrecision(),
                            originalEvent.getDeviceId(),
                            originalEvent.getEdgeFlags(),
                            originalEvent.getSource(),
                            originalEvent.getFlags());

            dispatchToChildren(rootView, newEvent);
            newEvent.recycle();

        } catch (Exception e) {
            Log.e(TAG, "Exception in dispatchGameCancelEvent", e);
        }
    }

    private int findPointerIndex(MotionEvent event, int pointerId) {
        for (int i = 0; i < event.getPointerCount(); i++) {
            if (event.getPointerId(i) == pointerId) {
                return i;
            }
        }
        return -1;
    }

    private void dispatchToChildren(ViewGroup parent, MotionEvent event) {
        for (int i = parent.getChildCount() - 1; i >= 0; i--) {
            View child = parent.getChildAt(i);

            if (IMGUI_VIEW_TAG.equals(child.getTag())) {
                continue;
            }

            try {
                if (child.getVisibility() == View.VISIBLE) {
                    float offsetX = child.getLeft();
                    float offsetY = child.getTop();

                    MotionEvent.PointerProperties[] props =
                            new MotionEvent.PointerProperties[event.getPointerCount()];
                    MotionEvent.PointerCoords[] coords =
                            new MotionEvent.PointerCoords[event.getPointerCount()];

                    for (int j = 0; j < event.getPointerCount(); j++) {
                        props[j] = new MotionEvent.PointerProperties();
                        coords[j] = new MotionEvent.PointerCoords();
                        event.getPointerProperties(j, props[j]);
                        event.getPointerCoords(j, coords[j]);

                        coords[j].x -= offsetX;
                        coords[j].y -= offsetY;
                    }

                    MotionEvent childEvent =
                            MotionEvent.obtain(
                                    event.getDownTime(),
                                    event.getEventTime(),
                                    event.getAction(),
                                    event.getPointerCount(),
                                    props,
                                    coords,
                                    event.getMetaState(),
                                    event.getButtonState(),
                                    event.getXPrecision(),
                                    event.getYPrecision(),
                                    event.getDeviceId(),
                                    event.getEdgeFlags(),
                                    event.getSource(),
                                    event.getFlags());

                    boolean handled = child.dispatchTouchEvent(childEvent);
                    childEvent.recycle();

                    if (handled) {
                        return;
                    }
                }
            } catch (Exception e) {
                Log.e(TAG, "Exception in dispatchToChildren", e);
            }
        }
    }

    // ========================================================================
    // 触摸区域检测
    // ========================================================================

    public static boolean isImGuiComponentTouched(float x, float y) {
        float[] bounds = nativeGetImGuiWindowBounds();
        if (bounds == null || bounds.length == 0) {
            return false;
        }

        int windowCount = bounds.length / 4;

        for (int i = 0; i < windowCount; i++) {
            int baseIndex = i * 4;
            float left = bounds[baseIndex];
            float top = bounds[baseIndex + 1];
            float right = bounds[baseIndex + 2];
            float bottom = bounds[baseIndex + 3];

            if (x >= left && x <= right && y >= top && y <= bottom) {
                return true;
            }
        }

        return false;
    }

    public static boolean isCircularButtonTouched(float x, float y) {
        float[] buttonBounds = nativeGetCircularButtonBounds();
        if (buttonBounds == null || buttonBounds.length == 0) {
            return false;
        }

        int count = (int) buttonBounds[0];
        for (int i = 0; i < count; i++) {
            int baseIndex = 1 + i * 3;
            if (baseIndex + 2 >= buttonBounds.length) break;

            float centerX = buttonBounds[baseIndex];
            float centerY = buttonBounds[baseIndex + 1];
            float radius = buttonBounds[baseIndex + 2];

            float dx = x - centerX;
            float dy = y - centerY;
            float distSq = dx * dx + dy * dy;

            if (distSq <= radius * radius) {
                return true;
            }
        }

        return false;
    }

    // ========================================================================
